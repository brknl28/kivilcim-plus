{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run App (HMR)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "KivilcimPlus.BreakCalculator.csproj",
        "run",
        "--launch-profile",
        "http"
      ],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
